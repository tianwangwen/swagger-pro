{
  "name": "Swagger Pro",
  "description": "Enhanced Swagger with global search, quick copy, bookmarking and sharing—boosting usability and efficiency",
  "version": "1.3",
  "manifest_version": 3,
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "Swagger Pro"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "scripts/content-state.js",
        "scripts/content-ui.js",
        "scripts/content-styles.js",
        "scripts/content-templates.js",
        "scripts/content-schema.js",
        "scripts/content-api-cards.js",
        "scripts/content-share.js",
        "scripts/content-events.js",
        "scripts/content-render.js",
        "scripts/content-page.js",
        "scripts/content-fetch.js",
        "scripts/content-features.js",
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/swagger.html", "images/icon-128.png", "images/icon-16.png", "images/icon-32.png", "images/icon-48.png", "images/logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
